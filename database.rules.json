{
  "rules": {
    "pending_bids": {
      "$bidId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['auctionId','itemId','userId','amount','timestamp']) && newData.child('userId').val() === auth.uid && newData.child('amount').isNumber() && newData.child('amount').val() > 0"
      }
    },
    "auction_items": {
      ".read": true,
      ".indexOn": ["auctionId", "order"],
      "$itemId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager')"
      }
    },
    "auctions": {
      ".read": true,
      ".indexOn": ["status"],
      "$auctionId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager')"
      }
    },
    "pre_bids": {
      "$auctionId": {
        "$itemId": {
          ".read": "auth != null",
          "$userId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId",
            ".validate": "newData.hasChildren(['userId','amount','timestamp']) && newData.child('userId').val() === auth.uid && newData.child('amount').isNumber() && newData.child('amount').val() > 0"
          }
        }
      }
    },
    "live_chat": {
      "$auctionId": {
        ".read": true,
        "$msgId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId','senderName','message','timestamp']) && newData.child('message').isString() && newData.child('message').val().length <= 300"
        }
      }
    },
    "registrations": {
      "$auctionId": {
        "$userId": {
          ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager')",
          ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager')"
        }
      }
    },
    "users": {
      "$userId": {
        ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "displayName": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "phone": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.isString()"
        },
        "email": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.isString()"
        },
        "role": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists() && newData.val() === 'participant') || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.isString() && (newData.val() === 'participant' || newData.val() === 'house_manager' || newData.val() === 'admin')"
        },
        "houseId": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        },
        "createdAt": {
          ".write": "auth != null && auth.uid === $userId && !data.exists()"
        }
      }
    },
    "bid_history": {
      ".read": true,
      ".write": false
    },
    "presence": {
      "$auctionId": {
        ".read": true,
        "$sessionId": {
          ".write": "auth != null"
        }
      }
    },
    "timer_locks": {
      "$auctionId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": false
      }
    }
  }
}
