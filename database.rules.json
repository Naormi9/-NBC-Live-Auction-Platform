{
  "rules": {
    "pending_bids": {
      "$bidId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('verificationStatus').val() === 'approved'",
        ".validate": "newData.hasChildren(['auctionId','itemId','userId','amount','timestamp']) && newData.child('userId').val() === auth.uid && newData.child('amount').isNumber() && newData.child('amount').val() > 0"
      }
    },
    "auction_items": {
      ".read": true,
      ".indexOn": ["auctionId", "order"],
      "$itemId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager') && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')"
      }
    },
    "auctions": {
      ".read": true,
      ".indexOn": ["status"],
      "$auctionId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager') && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')"
      }
    },
    "pre_bids": {
      "$auctionId": {
        "$itemId": {
          ".read": "auth != null",
          "$userId": {
            ".read": "auth != null && auth.uid === $userId",
            ".write": "auth != null && auth.uid === $userId && root.child('users').child(auth.uid).child('verificationStatus').val() === 'approved'",
            ".validate": "newData.hasChildren(['userId','amount','timestamp']) && newData.child('userId').val() === auth.uid && newData.child('amount').isNumber() && newData.child('amount').val() > 0"
          }
        }
      }
    },
    "live_chat": {
      "$auctionId": {
        ".read": true,
        "$msgId": {
          ".write": "auth != null",
          ".validate": "newData.hasChildren(['senderId','senderName','message','timestamp']) && (newData.child('senderId').val() === auth.uid || (newData.child('senderId').val() === 'system' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager'))) && newData.child('message').isString() && newData.child('message').val().length > 0 && newData.child('message').val().length <= 300"
        }
      }
    },
    "registrations": {
      "$auctionId": {
        "$userId": {
          ".read": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager')",
          ".write": "auth != null && ((auth.uid === $userId && newData.child('status').val() !== 'approved') || (root.child('users').child(auth.uid).child('role').val() === 'admin' && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')))"
        }
      }
    },
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      "$userId": {
        ".read": "auth != null && auth.uid === $userId",
        "displayName": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100"
        },
        "phone": {
          ".write": "auth != null && auth.uid === $userId",
          ".validate": "newData.isString()"
        },
        "email": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.isString()"
        },
        "idNumber": {
          ".write": "auth != null && auth.uid === $userId && !data.exists()",
          ".validate": "newData.isString() && newData.val().length === 9"
        },
        "role": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists() && newData.val() === 'participant') || (root.child('users').child(auth.uid).child('role').val() === 'admin' && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')))",
          ".validate": "newData.isString() && (newData.val() === 'participant' || newData.val() === 'house_manager' || newData.val() === 'admin')"
        },
        "verificationStatus": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists()) || (auth.uid === $userId && data.val() === 'pending_verification' && newData.val() === 'pending_approval'))",
          ".validate": "newData.isString() && (newData.val() === 'pending_verification' || newData.val() === 'pending_approval' || newData.val() === 'approved' || newData.val() === 'rejected')"
        },
        "termsAcceptedAt": {
          ".write": "auth != null && auth.uid === $userId && !data.exists()"
        },
        "signatureData": {
          ".write": "auth != null && auth.uid === $userId && !data.exists()",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 70000"
        },
        "callbackRequested": {
          ".write": "auth != null && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        },
        "houseId": {
          ".write": "auth != null && ((auth.uid === $userId && !data.exists()) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        },
        "createdAt": {
          ".write": "auth != null && auth.uid === $userId && !data.exists()"
        }
      }
    },
    "bid_history": {
      ".read": true,
      "$auctionId": {
        "$itemId": {
          "$bidId": {
            ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'house_manager') && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')",
            ".validate": "newData.hasChildren(['userId','userDisplayName','amount','round','timestamp'])"
          }
        }
      }
    },
    "houses": {
      ".read": "auth != null",
      "$houseId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin' && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')"
      }
    },
    "presence": {
      "$auctionId": {
        ".read": true,
        "$sessionId": {
          ".write": "auth != null"
        }
      }
    },
    "timer_locks": {
      "$auctionId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin' && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')",
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin' && (auth.token.email === 'ceo@m-motors.co.il' || auth.token.email === 'office@m-motors.co.il')"
      }
    }
  }
}
